<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Cheung Family | Giving Back</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --cream: #FAFAF7;
  --cream-warm: #F4F1EB;
  --cream-border: #E8E3DA;
  --emerald: #1A6B4A;
  --emerald-deep: #134F37;
  --emerald-light: #2A8A61;
  --emerald-pale: #EBF5F0;
  --gold: #C8952A;
  --gold-light: #F5E6C8;
  --gold-pale: #FBF5E9;
  --charcoal: #1C1C1C;
  --text-mid: #4A4A4A;
  --text-muted: #8A8A8A;
  --white: #FFFFFF;
}

html { scroll-behavior: smooth; }

body {
  background: var(--cream);
  color: var(--charcoal);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  line-height: 1.7;
  overflow-x: hidden;
}

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 3rem;
  transition: background 0.4s, box-shadow 0.4s;
}
nav.scrolled {
  background: rgba(250,250,247,0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 1px 0 var(--cream-border);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: 0.05em;
  color: var(--emerald-deep);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.nav-logo-mark {
  width: 28px; height: 28px;
  background: var(--emerald);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 0.7rem;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  flex-shrink: 0;
}
.nav-links {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}
.nav-links a {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  color: var(--text-mid);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--emerald); }

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  background: var(--white);
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  overflow: hidden;
  position: relative;
}

.hero-left {
  padding: 8rem 4rem 8rem 5rem;
  position: relative;
  z-index: 2;
}

.hero-right {
  position: relative;
  height: 100%;
  min-height: 100vh;
  overflow: hidden;
}
.hero-right img {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-right::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, white 0%, transparent 30%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--emerald-pale);
  color: var(--emerald);
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.45rem 1rem;
  border-radius: 50px;
  margin-bottom: 2rem;
  font-weight: 500;
  opacity: 0;
  transform: translateY(16px);
  animation: fadeUp 0.9s 0.2s ease forwards;
}
.hero-badge-dot {
  width: 6px; height: 6px;
  background: var(--emerald);
  border-radius: 50%;
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 5vw, 4.5rem);
  font-weight: 400;
  line-height: 1.12;
  color: var(--charcoal);
  margin-bottom: 1.5rem;
  opacity: 0;
  transform: translateY(24px);
  animation: fadeUp 1s 0.4s ease forwards;
}
.hero-title em {
  font-style: italic;
  color: var(--emerald);
}

.hero-body {
  font-size: 1.05rem;
  color: var(--text-mid);
  max-width: 420px;
  line-height: 1.85;
  margin-bottom: 2.75rem;
  opacity: 0;
  transform: translateY(16px);
  animation: fadeUp 0.9s 0.6s ease forwards;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  background: var(--emerald);
  color: white;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  padding: 0.9rem 2rem;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.3s, transform 0.2s;
  opacity: 0;
  animation: fadeUp 0.9s 0.8s ease forwards;
}
.btn-primary:hover { background: var(--emerald-deep); transform: translateY(-1px); }
.btn-arrow { font-size: 1rem; }

.hero-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 4rem;
  padding-top: 2.5rem;
  border-top: 1px solid var(--cream-border);
  opacity: 0;
  animation: fadeUp 0.9s 1s ease forwards;
}
.hero-stat .num {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 400;
  color: var(--charcoal);
  line-height: 1;
  display: block;
}
.hero-stat .lbl {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
  display: block;
  letter-spacing: 0.05em;
}

/* ─── SECTION BASE ─── */
.section-wrap {
  padding: 7rem 5rem;
  max-width: 1200px;
  margin: 0 auto;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--emerald);
  font-weight: 500;
  margin-bottom: 1.25rem;
}
.eyebrow::before {
  content: '';
  display: block;
  width: 24px; height: 1px;
  background: var(--emerald);
}

.section-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  line-height: 1.18;
  color: var(--charcoal);
  margin-bottom: 1rem;
}
.section-h em { font-style: italic; color: var(--emerald); }

/* ─── ABOUT STRIP ─── */
.about-strip {
  background: var(--white);
  padding: 7rem 5rem;
}
.about-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 6rem;
  align-items: center;
}
.about-image-wrap {
  position: relative;
}
.about-image-wrap img {
  width: 100%;
  aspect-ratio: 4/5;
  object-fit: cover;
  border-radius: 12px;
  display: block;
}
.about-image-badge {
  position: absolute;
  bottom: -1.5rem;
  right: -1.5rem;
  background: var(--gold-pale);
  border: 1px solid var(--gold-light);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  text-align: center;
}
.about-image-badge .big { 
  font-family: 'Playfair Display', serif;
  font-size: 2.25rem; 
  color: var(--gold); 
  line-height: 1;
  display: block;
}
.about-image-badge .small { 
  font-size: 0.72rem; 
  color: var(--text-muted); 
  letter-spacing: 0.05em;
  display: block;
  margin-top: 0.2rem;
}

.about-text p {
  color: var(--text-mid);
  font-size: 1rem;
  margin-bottom: 1.25rem;
}

.values-row {
  display: flex;
  gap: 1rem;
  margin-top: 2.5rem;
  flex-wrap: wrap;
}
.value-pill {
  background: var(--emerald-pale);
  color: var(--emerald-deep);
  font-size: 0.8rem;
  font-weight: 500;
  padding: 0.5rem 1.1rem;
  border-radius: 50px;
  letter-spacing: 0.04em;
}

/* ─── TIMELINE ─── */
.timeline-bg {
  background: var(--cream-warm);
  padding: 7rem 5rem;
}
.timeline-inner {
  max-width: 900px;
  margin: 0 auto;
}

.timeline {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.tl-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 2.5rem;
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--cream-border);
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.tl-item:last-child { border-bottom: none; }
.tl-item.visible { opacity: 1; transform: translateY(0); }

.tl-year-wrap { text-align: right; padding-top: 0.35rem; }
.tl-year {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 400;
  color: var(--emerald);
  display: block;
}
.tl-status {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  display: block;
  margin-top: 0.25rem;
}

.tl-dot-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0.5rem;
  width: 20px;
  flex-shrink: 0;
}

.tl-content h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.35rem;
  font-weight: 400;
  color: var(--charcoal);
  margin-bottom: 0.6rem;
}
.tl-content p {
  font-size: 0.92rem;
  color: var(--text-mid);
  line-height: 1.8;
}

.tl-tag {
  display: inline-block;
  background: var(--emerald-pale);
  color: var(--emerald);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.75rem;
  border-radius: 50px;
  margin-bottom: 0.75rem;
}

/* ─── INITIATIVE CARDS ─── */
.cards-section {
  background: var(--white);
  padding: 7rem 5rem;
}
.cards-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 3.5rem;
}
.card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--cream-border);
  transition: box-shadow 0.4s, transform 0.3s;
  background: var(--white);
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.3s;
}
.card.visible { opacity: 1; transform: translateY(0); }
.card:hover { box-shadow: 0 12px 40px rgba(26,107,74,0.12); transform: translateY(-5px); }

.card-img {
  height: 210px;
  overflow: hidden;
  position: relative;
}
.card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  filter: brightness(0.88);
}
.card:hover .card-img img { transform: scale(1.06); filter: brightness(0.95); }
.card-img-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(255,255,255,0.9), transparent);
}

.card-body { padding: 1.5rem 1.75rem; }
.card-tag-pill {
  display: inline-block;
  background: var(--emerald-pale);
  color: var(--emerald);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.75rem;
  border-radius: 50px;
  margin-bottom: 0.85rem;
}
.card-title-h {
  font-family: 'Playfair Display', serif;
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--charcoal);
  margin-bottom: 0.65rem;
  line-height: 1.3;
}
.card-body p {
  font-size: 0.87rem;
  color: var(--text-mid);
  line-height: 1.75;
}

.card-foot {
  padding: 1rem 1.75rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.card-year-lbl {
  font-size: 0.78rem;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}
.card-cta {
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--emerald);
  display: flex;
  align-items: center;
  gap: 0.3rem;
  text-decoration: none;
  transition: gap 0.2s;
}
.card:hover .card-cta { gap: 0.6rem; }

/* ─── QUOTE ─── */
.quote-section {
  background: var(--emerald);
  padding: 7rem 5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.quote-section::before {
  content: '"';
  position: absolute;
  top: -2rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Playfair Display', serif;
  font-size: 20rem;
  color: rgba(255,255,255,0.05);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}
.quote-inner { max-width: 760px; margin: 0 auto; position: relative; z-index: 1; }
blockquote {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.5rem, 3.5vw, 2.4rem);
  font-weight: 400;
  font-style: italic;
  color: white;
  line-height: 1.5;
  margin-bottom: 2rem;
}
.q-attr {
  font-size: 0.78rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}

/* ─── FOOTER ─── */
footer {
  background: var(--charcoal);
  padding: 3.5rem 5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  color: white;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.footer-logo-mark {
  width: 26px; height: 26px;
  background: var(--emerald);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  color: white;
  font-style: italic;
  font-family: 'Playfair Display', serif;
}
.footer-copy {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.4);
}

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .hero-left { padding: 7rem 2rem 5rem; }
  .about-inner { grid-template-columns: 1fr; gap: 3rem; }
  .cards-grid { grid-template-columns: 1fr; }
  .section-wrap, .about-strip, .timeline-bg, .cards-section, .quote-section { padding: 5rem 1.75rem; }
  nav { padding: 1rem 1.5rem; }
  .nav-links { display: none; }
  footer { padding: 2.5rem 1.75rem; flex-direction: column; align-items: flex-start; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">
    <span class="nav-logo-mark">C</span>
    Cheung Family
  </a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#giving">Our Giving</a></li>
    <li><a href="#initiatives">Initiatives</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Cheung Family Foundation · Singapore
    </div>
    <h1 class="hero-title">
      Giving that<br>
      <em>grows</em> with<br>
      every generation
    </h1>
    <p class="hero-body">
      We invest in education, health, and community — not because it is expected of us, but because we believe every act of generosity plants a seed that outlasts us.
    </p>
    <a href="#giving" class="btn-primary">
      Our giving journey
      <span class="btn-arrow">↓</span>
    </a>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="num">2</span>
        <span class="lbl">University scholarships</span>
      </div>
      <div class="hero-stat">
        <span class="num">3+</span>
        <span class="lbl">Charitable causes</span>
      </div>
      <div class="hero-stat">
        <span class="num">∞</span>
        <span class="lbl">Lives touched</span>
      </div>
    </div>
  </div>
  <div class="hero-right">
    <img src="https://images.unsplash.com/photo-1531545514256-b1400bc00f31?w=1200&q=85&auto=format" alt="Family, community, togetherness">
  </div>
</section>

<!-- ABOUT -->
<div class="about-strip" id="about">
  <div class="about-inner">
    <div class="about-image-wrap">
      <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=900&q=85&auto=format" alt="Graduation — the joy of education">
      <div class="about-image-badge">
        <span class="big">Est.</span>
        <span class="small">Singapore</span>
      </div>
    </div>
    <div class="about-text">
      <p class="eyebrow">Our Mission</p>
      <h2 class="section-h">A family's commitment to <em>leaving things better</em></h2>
      <p>The Cheung family believes in the compounding power of generosity. Like interest in a long-held investment, giving — done consistently and with intention — builds something far greater than any single gift.</p>
      <p>Our philanthropic focus is education and childhood health: the two pillars that, more than any other, determine what a person can become. By funding scholarships at Singapore's leading universities and supporting children battling illness, we aim to widen the door of possibility for those who deserve it most.</p>
      <p>We are grateful to be in a position to give, and we take that responsibility seriously.</p>
      <div class="values-row">
        <span class="value-pill">Education</span>
        <span class="value-pill">Healthcare</span>
        <span class="value-pill">Community</span>
        <span class="value-pill">Singapore</span>
      </div>
    </div>
  </div>
</div>

<!-- TIMELINE -->
<div class="timeline-bg" id="giving">
  <div class="timeline-inner">
    <p class="eyebrow">A Journey of Giving</p>
    <h2 class="section-h">Our giving, <em>year by year</em></h2>

    <div class="timeline">
      <div class="tl-item">
        <div class="tl-year-wrap">
          <span class="tl-year">∞</span>
          <span class="tl-status">Ongoing</span>
        </div>
        <div class="tl-content">
          <div class="tl-tag">Healthcare · Children</div>
          <h3>Children's Cancer Foundation</h3>
          <p>We contribute regularly to Singapore's Children's Cancer Foundation, supporting the psychosocial care, education and financial assistance provided to children with cancer and their families. Because a diagnosis should never determine a child's future.</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-year-wrap">
          <span class="tl-year">2025</span>
          <span class="tl-status">Active</span>
        </div>
        <div class="tl-content">
          <div class="tl-tag">Education · SMU</div>
          <h3>Cheung Family Scholarship at SMU</h3>
          <p>Established an endowed scholarship at Singapore Management University for students of academic merit and financial need. With MOE's matching grant, every dollar we give reaches further. Our hope is that recipients carry both the opportunity and the spirit of giving forward.</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-year-wrap">
          <span class="tl-year">2026</span>
          <span class="tl-status">Active</span>
        </div>
        <div class="tl-content">
          <div class="tl-tag">Education · NUS</div>
          <h3>Cheung Family Scholarship at NUS</h3>
          <p>A second scholarship endowed at the National University of Singapore — widening our reach and deepening our commitment to higher education. NUS's global standing makes this an investment not just in a student, but in Singapore's place in the world.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- INITIATIVE CARDS -->
<div class="cards-section" id="initiatives">
  <div class="cards-inner">
    <p class="eyebrow">Our Initiatives</p>
    <h2 class="section-h">Where we <em>direct our giving</em></h2>
    <div class="cards-grid">

      <div class="card">
        <div class="card-img">
          <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?w=800&q=80&auto=format" alt="SMU Singapore Management University">
          <div class="card-img-overlay"></div>
        </div>
        <div class="card-body">
          <span class="card-tag-pill">Education · Singapore</span>
          <h3 class="card-title-h">Cheung Family Scholarship — SMU</h3>
          <p>Supporting bright minds at Singapore Management University since 2025. Our scholarship goes to students who combine academic excellence with the drive to contribute back to their communities.</p>
        </div>
        <div class="card-foot">
          <span class="card-year-lbl">Established 2025</span>
          <a href="https://www.smu.edu.sg" target="_blank" class="card-cta">Learn more →</a>
        </div>
      </div>

      <div class="card">
        <div class="card-img">
          <img src="https://images.unsplash.com/photo-1498243691581-b145c3f54a5a?w=800&q=80&auto=format" alt="NUS National University of Singapore">
          <div class="card-img-overlay"></div>
        </div>
        <div class="card-body">
          <span class="card-tag-pill">Education · Singapore</span>
          <h3 class="card-title-h">Cheung Family Scholarship — NUS</h3>
          <p>Our 2026 scholarship at NUS reflects our belief that Singapore's best university should be accessible to all who deserve it — regardless of financial background.</p>
        </div>
        <div class="card-foot">
          <span class="card-year-lbl">Established 2026</span>
          <a href="https://www.nus.edu.sg" target="_blank" class="card-cta">Learn more →</a>
        </div>
      </div>

